// Prisma Schema for EduManager
// PostgreSQL (Supabase) compatible

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================================
// USERS TABLE (Authentication)
// ========================================
model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(receptionist)
  fullName     String    @map("full_name")
  email        String?
  phone        String?
  status       Status    @default(active)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  templates            Template[]
  receipts             Receipt[]
  payments             Payment[]
  activityLogs         ActivityLog[]
  progressCreated      StudentProgressMonth[]      @relation("ProgressCreatedBy")
  progressUpdated      StudentProgressMonth[]      @relation("ProgressUpdatedBy")
  progressDailyEntries StudentProgressDailyEntry[] @relation("ProgressDailyCreatedBy")
  attendanceCreated    Attendance[]                @relation("AttendanceCreator")
  periodSubmitted      AttendancePeriod[]          @relation("PeriodSubmitter")
  periodApproved       AttendancePeriod[]          @relation("PeriodApprover")
  periodLocked         AttendancePeriod[]          @relation("PeriodLocker")

  @@index([username])
  @@index([role])
  @@map("users")
}

enum UserRole {
  admin
  receptionist
}

enum Status {
  active
  inactive
}

// ========================================
// PARENTS TABLE
// ========================================
model Parent {
  id           String       @id @default(cuid())
  fullName     String       @map("full_name")
  phone        String       @unique
  email        String?
  address      String?
  relationship Relationship
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  // Relations
  students Student[]

  @@index([phone])
  @@index([fullName])
  @@index([deletedAt])
  @@map("parents")
}

enum Relationship {
  father
  mother
  guardian
}

// ========================================
// STUDENTS TABLE
// ========================================
model Student {
  id             String        @id @default(cuid())
  fullName       String        @map("full_name")
  dateOfBirth    DateTime      @map("date_of_birth")
  gender         Gender
  parentId       String        @map("parent_id")
  phone          String?
  email          String?
  address        String?
  enrollmentDate DateTime      @map("enrollment_date")
  graduationDate DateTime?     @map("graduation_date")
  status         StudentStatus @default(active)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  // Relations
  parent            Parent                 @relation(fields: [parentId], references: [id])
  studentClasses    StudentClass[]
  attendance        Attendance[]
  monthlyFees       MonthlyFee[]
  monthlyFeeLines   MonthlyFeeLine[]
  receipts          Receipt[]
  progressMonths    StudentProgressMonth[]
  enrollmentPeriods EnrollmentPeriod[]

  @@index([parentId])
  @@index([status])
  @@index([fullName])
  @@index([deletedAt])
  @@map("students")
}

enum Gender {
  male
  female
  other
}

enum StudentStatus {
  active
  inactive
  graduated
}

// ========================================
// TEACHERS TABLE
// ========================================
model Teacher {
  id           String     @id @default(cuid())
  fullName     String     @map("full_name")
  phone        String     @unique
  email        String?
  salaryType   SalaryType @map("salary_type")
  salaryAmount Float      @map("salary_amount")
  status       Status     @default(active)
  notes        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  classes Class[]

  @@index([phone])
  @@index([status])
  @@map("teachers")
}

enum SalaryType {
  hourly
  fixed
}

// ========================================
// CLASSES TABLE
// ========================================
model Class {
  id        String @id @default(cuid())
  className String @map("class_name")

  // Schedule options (flexible attendance)
  scheduleDays     Json?   @map("schedule_days") // [2,4,6] = T2, T4, T6 (optional)
  scheduleRequired Boolean @default(false) @map("schedule_required") // Bắt buộc đúng ngày
  sessionsPerWeek  Int?    @map("sessions_per_week") // Số buổi/tuần (optional)
  sessionRequired  Boolean @default(false) @map("session_required") // Bắt buộc đúng số buổi

  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  feePerDay   Float    @map("fee_per_day")
  maxStudents Int      @default(50) @map("max_students")
  teacherId   String?  @map("teacher_id")
  status      Status   @default(active)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  teacher           Teacher?               @relation(fields: [teacherId], references: [id])
  studentClasses    StudentClass[]
  attendance        Attendance[]
  attendancePeriods AttendancePeriod[]
  monthlyFeeLines   MonthlyFeeLine[]
  receiptLines      ReceiptLine[]
  progressMonths    StudentProgressMonth[]
  enrollmentPeriods EnrollmentPeriod[]

  @@index([teacherId])
  @@index([status])
  @@map("classes")
}

// ========================================
// STUDENT_CLASSES (Many-to-Many Link)
// ========================================
model StudentClass {
  id             Int      @id @default(autoincrement())
  studentId      String   @map("student_id")
  classId        String   @map("class_id")
  enrollmentDate DateTime @map("enrollment_date")
  status         Status   @default(active)
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
  @@index([classId, status])
  @@index([studentId, status])
  @@map("student_classes")
}

// Immutable enrollment history. StudentClass remains the current-state projection.
model EnrollmentPeriod {
  id        String    @id @default(cuid())
  studentId String    @map("student_id")
  classId   String    @map("class_id")
  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")
  source    String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId, startedAt, endedAt])
  @@index([classId, startedAt, endedAt])
  @@index([studentId, classId, endedAt])
  @@map("enrollment_periods")
}

// ========================================
// ATTENDANCE TABLE
// ========================================
model Attendance {
  id             String           @id @default(cuid())
  studentId      String           @map("student_id")
  classId        String           @map("class_id")
  attendanceDate DateTime         @map("attendance_date")
  status         AttendanceStatus
  reason         String?

  // Make-up class tracking
  isMakeUp     Boolean @default(false) @map("is_make_up")
  makeUpReason String? @map("make_up_reason") // học bù, học thêm, etc.

  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  student   Student @relation(fields: [studentId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])
  createdBy User    @relation("AttendanceCreator", fields: [createdById], references: [id])

  @@unique([studentId, classId, attendanceDate])
  @@index([studentId])
  @@index([classId])
  @@index([attendanceDate])
  @@index([classId, attendanceDate])
  @@index([studentId, attendanceDate])
  @@index([attendanceDate, status])
  @@index([isMakeUp])
  @@map("attendance")
}

enum AttendanceStatus {
  present
  absent_with_fee
  absent_no_fee
  holiday
}

// ========================================
// ATTENDANCE_PERIODS TABLE (SAP Timesheet)
// ========================================
model AttendancePeriod {
  id               String       @id @default(cuid())
  classId          String       @map("class_id")
  periodMonth      String       @map("period_month") // YYYY-MM format
  status           PeriodStatus @default(open)
  totalSessions    Int          @default(0) @map("total_sessions")
  totalPresent     Int          @default(0) @map("total_present")
  totalAbsentFee   Int          @default(0) @map("total_absent_fee")
  totalAbsentNoFee Int          @default(0) @map("total_absent_no_fee")
  totalHoliday     Int          @default(0) @map("total_holiday")
  submittedById    String?      @map("submitted_by")
  submittedAt      DateTime?    @map("submitted_at")
  approvedById     String?      @map("approved_by")
  approvedAt       DateTime?    @map("approved_at")
  lockedById       String?      @map("locked_by")
  lockedAt         DateTime?    @map("locked_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  class       Class @relation(fields: [classId], references: [id])
  submittedBy User? @relation("PeriodSubmitter", fields: [submittedById], references: [id])
  approvedBy  User? @relation("PeriodApprover", fields: [approvedById], references: [id])
  lockedBy    User? @relation("PeriodLocker", fields: [lockedById], references: [id])

  @@unique([classId, periodMonth])
  @@index([classId])
  @@index([periodMonth])
  @@index([status])
  @@index([classId, periodMonth, status])
  @@map("attendance_periods")
}

enum PeriodStatus {
  open
  submitted
  approved
  locked
}

// ========================================
// MONTHLY_FEES TABLE (Fee Collection)
// ========================================
model MonthlyFee {
  id          String    @id @default(cuid())
  studentId   String    @map("student_id")
  month       String // YYYY-MM format
  totalDays   Int       @default(0) @map("total_days")
  totalAmount Float     @default(0) @map("total_amount")
  status      FeeStatus @default(pending)
  receiptId   String?   @map("receipt_id")
  paidAt      DateTime? @map("paid_at")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  student Student          @relation(fields: [studentId], references: [id])
  receipt Receipt?         @relation(fields: [receiptId], references: [id])
  lines   MonthlyFeeLine[]

  @@unique([studentId, month])
  @@index([studentId])
  @@index([month])
  @@index([status])
  @@index([month, status])
  @@index([studentId, month])
  @@map("monthly_fees")
}

model MonthlyFeeLine {
  id                   String    @id @default(cuid())
  monthlyFeeId         String    @map("monthly_fee_id")
  studentId            String    @map("student_id")
  classId              String?   @map("class_id")
  allocationKey        String    @map("allocation_key")
  month                String
  classNameSnapshot    String?   @map("class_name_snapshot")
  teacherNameSnapshot  String?   @map("teacher_name_snapshot")
  expectedSessions     Int       @default(0) @map("expected_sessions")
  chargedSessions      Int       @default(0) @map("charged_sessions")
  makeUpSessions       Int       @default(0) @map("make_up_sessions")
  extraSessions        Int       @default(0) @map("extra_sessions")
  feePerSession        Float     @default(0) @map("fee_per_session")
  monthlyTuition       Float     @default(0) @map("monthly_tuition")
  amount               Float     @default(0)
  billingMode          String?   @map("billing_mode")
  scheduleMode         String?   @map("schedule_mode")
  status               FeeStatus @default(pending)
  receiptId            String?   @map("receipt_id")
  paidAt               DateTime? @map("paid_at")
  allocationConfidence String    @default("calculated") @map("allocation_confidence")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  monthlyFee   MonthlyFee    @relation(fields: [monthlyFeeId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id])
  class        Class?        @relation(fields: [classId], references: [id])
  receipt      Receipt?      @relation(fields: [receiptId], references: [id])
  receiptLines ReceiptLine[]

  @@unique([studentId, month, allocationKey])
  @@index([monthlyFeeId])
  @@index([studentId, month])
  @@index([classId, month, status])
  @@index([receiptId])
  @@map("monthly_fee_lines")
}

enum FeeStatus {
  pending
  ready
  confirmed
  paid
}

// ========================================
// TEMPLATES TABLE
// ========================================
model Template {
  id           String       @id @default(cuid())
  templateName String       @map("template_name")
  type         TemplateType
  paperSize    PaperSize    @map("paper_size")
  orientation  Orientation
  jsonConfig   Json         @map("json_config") // Full canvas configuration
  isDefault    Boolean      @default(false) @map("is_default")
  createdById  String       @map("created_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  createdBy User      @relation(fields: [createdById], references: [id])
  receipts  Receipt[]
  payments  Payment[]

  @@index([type])
  @@index([isDefault])
  @@map("templates")
}

enum TemplateType {
  receipt
  payment
}

enum PaperSize {
  a4
  a5
  letter
  thermal_80mm
}

enum Orientation {
  portrait
  landscape
}

// ========================================
// RECEIPTS TABLE (Phiếu Thu)
// ========================================
model Receipt {
  id            String        @id @default(cuid())
  studentId     String        @map("student_id")
  month         String // YYYY-MM format
  daysCount     Int           @map("days_count")
  feePerDay     Float         @map("fee_per_day")
  amount        Float
  paymentMethod PaymentMethod @map("payment_method")
  templateId    String        @map("template_id")
  notes         String?
  pdfPath       String?       @map("pdf_path")
  createdById   String        @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  deletedAt     DateTime?     @map("deleted_at")

  // Relations
  student         Student          @relation(fields: [studentId], references: [id])
  template        Template         @relation(fields: [templateId], references: [id])
  createdBy       User             @relation(fields: [createdById], references: [id])
  monthlyFees     MonthlyFee[]
  monthlyFeeLines MonthlyFeeLine[]
  receiptLines    ReceiptLine[]

  @@index([studentId])
  @@index([month])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([studentId, month])
  @@map("receipts")
}

model ReceiptLine {
  id                  String   @id @default(cuid())
  receiptId           String   @map("receipt_id")
  monthlyFeeLineId    String?  @map("monthly_fee_line_id")
  classId             String?  @map("class_id")
  classNameSnapshot   String?  @map("class_name_snapshot")
  teacherNameSnapshot String?  @map("teacher_name_snapshot")
  daysCount           Int      @default(0) @map("days_count")
  expectedSessions    Int?     @map("expected_sessions")
  feePerDay           Float    @default(0) @map("fee_per_day")
  amount              Float    @default(0)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  receipt        Receipt         @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  monthlyFeeLine MonthlyFeeLine? @relation(fields: [monthlyFeeLineId], references: [id])
  class          Class?          @relation(fields: [classId], references: [id])

  @@index([receiptId])
  @@index([monthlyFeeLineId])
  @@index([classId])
  @@map("receipt_lines")
}

enum PaymentMethod {
  cash
  transfer
}

// ========================================
// PAYMENTS TABLE (Phiếu Chi)
// ========================================
model Payment {
  id             String          @id @default(cuid())
  category       PaymentCategory
  amount         Float
  recipientName  String          @map("recipient_name")
  recipientPhone String?         @map("recipient_phone")
  templateId     String          @map("template_id")
  notes          String?
  pdfPath        String?         @map("pdf_path")
  createdById    String          @map("created_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  deletedAt      DateTime?       @map("deleted_at")

  // Relations
  template  Template @relation(fields: [templateId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([category, createdAt])
  @@map("payments")
}

enum PaymentCategory {
  salary
  utility
  office
  other
}

// ========================================
// ACTIVITY_LOGS TABLE
// ========================================
model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ========================================
// STUDENT_PROGRESS TABLES
// ========================================
model StudentProgressMonth {
  id                       String    @id @default(cuid())
  studentId                String    @map("student_id")
  classId                  String    @map("class_id")
  month                    String
  trackKey                 String?   @map("track_key")
  classType                String?   @map("class_type")
  progressScore            Float     @default(0) @map("progress_score")
  attendanceScore          Float     @default(0) @map("attendance_score")
  consistencyScore         Float     @default(0) @map("consistency_score")
  learningEvidenceCoverage Float     @default(0) @map("learning_evidence_coverage")
  trackReadiness           String?   @map("track_readiness")
  focusSkillKey            String?   @map("focus_skill_key")
  focusSkillLabel          String?   @map("focus_skill_label")
  teacherNote              String?   @map("teacher_note")
  parentSummary            String?   @map("parent_summary")
  nextActions              Json?     @map("next_actions")
  evidenceNotes            Json?     @map("evidence_notes")
  rubricSnapshot           Json?     @map("rubric_snapshot")
  academicInputStatus      String?   @map("academic_input_status")
  shieldTotal              Int       @default(0) @map("shield_total")
  pointsTotal              Int       @default(0) @map("points_total")
  mockTestScore            Float?    @map("mock_test_score")
  dailyAverageScore        Float?    @map("daily_average_score")
  dailyLatestScore         Float?    @map("daily_latest_score")
  dailyScoreDelta          Float?    @map("daily_score_delta")
  dailyAssessmentCount     Int       @default(0) @map("daily_assessment_count")
  finalizedAt              DateTime? @map("finalized_at")
  createdById              String    @map("created_by")
  updatedById              String?   @map("updated_by")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  student      Student                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class                       @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy    User                        @relation("ProgressCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?                       @relation("ProgressUpdatedBy", fields: [updatedById], references: [id])
  skills       StudentProgressSkill[]
  dailyEntries StudentProgressDailyEntry[]

  @@unique([studentId, classId, month])
  @@index([studentId])
  @@index([classId])
  @@index([month])
  @@index([trackKey])
  @@index([classType])
  @@index([finalizedAt])
  @@index([studentId, classId, month])
  @@map("student_progress_months")
}

model StudentProgressSkill {
  id              String   @id @default(cuid())
  progressMonthId String   @map("progress_month_id")
  skillKey        String   @map("skill_key")
  skillLabel      String   @map("skill_label")
  score           Float?   @map("score")
  maxScore        Float    @default(100) @map("max_score")
  weight          Float    @default(0)
  status          String   @default("missing_input")
  note            String?
  source          String?  @map("source")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  progressMonth StudentProgressMonth @relation(fields: [progressMonthId], references: [id], onDelete: Cascade)

  @@unique([progressMonthId, skillKey])
  @@index([progressMonthId])
  @@index([skillKey])
  @@map("student_progress_skills")
}

enum ProgressEntryType {
  homework
  daily_practice
  skill_assessment
  mock_test
  shield
  note
}

model StudentProgressDailyEntry {
  id              String            @id @default(cuid())
  progressMonthId String            @map("progress_month_id")
  entryDate       DateTime          @map("entry_date")
  entryType       ProgressEntryType @map("entry_type")
  skillKey        String?           @map("skill_key")
  score           Float?            @map("score")
  shieldCount     Int               @default(0) @map("shield_count")
  note            String?
  createdById     String            @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  progressMonth StudentProgressMonth @relation(fields: [progressMonthId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("ProgressDailyCreatedBy", fields: [createdById], references: [id])

  @@index([progressMonthId])
  @@index([progressMonthId, entryDate])
  @@index([entryDate])
  @@index([entryType])
  @@index([skillKey])
  @@map("student_progress_daily_entries")
}

// ========================================
// CENTER_SETTINGS TABLE
// ========================================
model CenterSettings {
  id            Int      @id @default(1)
  centerName    String   @default("Trung Tâm Dạy Thêm") @map("center_name")
  centerAddress String?  @map("center_address")
  centerPhone   String?  @map("center_phone")
  centerEmail   String?  @map("center_email")
  centerLogo    String?  @map("center_logo") // Path to logo file
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("center_settings")
}
